#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan            = &kscan0;
        zmk,matrix_transform = &default_transform;
        zmk,battery          = &vbatt;
        zmk,backlight        = &backlight;
    };

    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <18>;
        rows    = <6>;
        map = <
RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15) RC(0,16) RC(0,17)
RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15) RC(1,16) RC(1,17)
RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)  RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15) RC(2,16) RC(2,17)
RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)  RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14) RC(3,15) RC(3,16) RC(3,17)
RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)  RC(4,6)  RC(4,7)  RC(4,8)  RC(4,9)  RC(4,10) RC(4,11) RC(4,12) RC(4,13) RC(4,14) RC(4,15) RC(4,16) RC(4,17)
RC(5,0)  RC(5,1)  RC(5,2)  RC(5,3)  RC(5,4)  RC(5,5)  RC(5,6)  RC(5,7)  RC(5,8)  RC(5,9)  RC(5,10) RC(5,11) RC(5,12) RC(5,13) RC(5,14) RC(5,15) RC(5,16) RC(5,17)
        >;
    };

    kscan0: kscan {
        compatible      = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";

        /*
         * Row GPIOs (both halves identical — same pin labels):
         *  row1 = D6  = P1.00  (pin10)
         *  row2 = D5  = P0.24  (pin9)
         *  row3 = D4  = P0.22  (pin8)
         *  row4 = D2  = P0.17  (pin6)
         *  row5 = D0  = P0.08  (pin3)
         *  row6 = D3  = P0.20  (pin7)
         */
        row-gpios
            = <&gpio1 0  GPIO_ACTIVE_HIGH>   /* row1 = D6  = P1.00 */
            , <&gpio0 24 GPIO_ACTIVE_HIGH>   /* row2 = D5  = P0.24 */
            , <&gpio0 22 GPIO_ACTIVE_HIGH>   /* row3 = D4  = P0.22 */
            , <&gpio0 20 GPIO_ACTIVE_HIGH>   /* row4 = D3  = P0.20 */
            , <&gpio0 17 GPIO_ACTIVE_HIGH>   /* row5 = D2  = P0.17 */
            , <&gpio0 8  GPIO_ACTIVE_HIGH>   /* row6 = D0  = P0.08 */
            ;

        /*
         * Col GPIOs (both halves identical — same physical pins):
         *  col1 = D7  = P0.11  (pin11)
         *  col2 = D8  = P1.04  (pin12)
         *  col3 = D9  = P1.06  (pin13)
         *  col4 = P1.07        (pin27)
         *  col5 = P1.02        (pin28)
         *  col6 = P1.01        (pin29)
         *  col7 = D14 = P1.13  (pin24)
         *  col8 = D16 = P0.10  (pin25)
         *  col9 = D10 = P1.11  (pin26)
         */
        col-gpios
            = <&gpio0 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col1 = D7  = P0.11 */
            , <&gpio1 4  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col2 = D8  = P1.04 */
            , <&gpio1 6  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col3 = D9  = P1.06 */
            , <&gpio1 7  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col4 = P1.07 */
            , <&gpio1 2  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col5 = P1.02 */
            , <&gpio1 1  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col6 = P1.01 */
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col7 = D14 = P1.13 */
            , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col8 = D16 = P0.10 */
            , <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* col9 = D10 = P1.11 */
            ;
    };

    vbatt: vbatt {
        compatible  = "zmk,battery-voltage-divider";
        io-channels = <&adc 7>;
        output-ohms = <2000000>;
        full-ohms   = <2820000>;
    };
};

&adc { status = "okay"; };
